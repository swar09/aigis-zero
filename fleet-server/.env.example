# EDR Fleet Server Environment Variables

# Server
HOST=0.0.0.0
PORT=50051

# Database
# Example: postgres://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgres://edr:edr_dev_secret@localhost:5433/edr_fleet

# Kafka (handled by kafka-handler, optional if disabled)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_AGENTS_EVENTS=edr-agent-events

# Auth — replace with a real 256-bit secret before any deployment
JWT_SECRET=change-me-to-a-256-bit-random-hex-string-in-production

# Logging
RUST_LOG=info
LOG_FORMAT=human
