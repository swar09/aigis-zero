# Aigis-Zero Agent — osquery flags
# eBPF-only: auditd disabled, BPF events enabled
# Managed by aigis-zero. Do not edit manually.

# Core paths
--config_plugin=filesystem
--config_path=/etc/osquery/osquery.conf
--config_refresh=300
--config_accelerated_refresh=120
--database_path=/var/osquery/osquery.db
--pidfile=/run/osquery/osqueryd.pid
--force=true

# Extensions socket (our Thrift client connects here)
--disable_extensions=false
--extensions_socket=/var/osquery/osquery.em
--extensions_autoload=/etc/osquery/extensions.load
--extensions_timeout=10
--extensions_interval=3

# Logging
--logger_plugin=filesystem
--logger_path=/var/log/osquery/
--logger_mode=0640
--logger_rotate=true
--logger_rotate_size=26214400
--logger_rotate_max_files=25
--logger_event_type=true
--logger_snapshot_event_type=true
--logger_min_status=0
--logger_stderr=true

# Events — eBPF only
--disable_events=false
--disable_audit=true
--enable_bpf_events=true
--events_expiry=3600
--events_max=500000
--events_optimize=true
--events_enforce_denylist=false

# BPF tuning (adjust bpf_buffer_storage_size=64 on VMs with many virtual CPUs)
# --bpf_perf_event_array_exp=10
# --bpf_buffer_storage_size=512

# Watchdog
--watchdog_level=0
--watchdog_memory_limit=400
--watchdog_utilization_limit=25
--watchdog_delay=90
--watchdog_forced_shutdown_delay=4

# Scheduling
--schedule_splay_percent=10
--schedule_max_drift=60
--schedule_default_interval=3600

# Host identity (stable across reboots)
--host_identifier=uuid

# Performance
--table_delay=0
--malloc_trim_threshold=200
--value_max=512
--hash_cache_max=500
--hash_delay=20
--read_max=52428800

--utc=true
--verbose=false
